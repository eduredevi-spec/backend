# Server
PORT=3000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/money-manager

# JWT Secrets (CHANGE THESE IN PRODUCTION — use long random strings)
JWT_ACCESS_SECRET=your-super-secret-access-key-change-this
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this

# CORS
CORS_ORIGIN=http://localhost:3001

# Email (needed for password reset and email verification)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password
EMAIL_FROM=noreply@moneymanager.com

# Encryption (optional — for field-level encryption)
# Must be exactly 64 hex characters (32 bytes)
# ENCRYPTION_KEY=
